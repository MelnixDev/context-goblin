{
  "name": "context-goblin",
  "version": "0.1.4",
  "description": "OpenCode plugin for AI coding agents that caches safe repo context, code maps, and token-usage evidence.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke:opencode": "bash scripts/smoke-opencode.sh",
    "check:models:general": "bash scripts/model-ab.sh",
    "check:tokens": "TOKEN_REPORT=1 bash scripts/model-ab.sh",
    "check:reports": "node scripts/check-reports.mjs",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build && npm run check:reports"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "plugin",
    "context",
    "context-cache",
    "ai-agent",
    "coding-agent",
    "token-optimization",
    "token-reduction",
    "repo-context",
    "code-map"
  ],
  "author": "Volodymyr Melnychuk",
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "^1.17.13"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MelnixDev/context-goblin.git"
  },
  "directories": {
    "test": "tests"
  },
  "bugs": {
    "url": "https://github.com/MelnixDev/context-goblin/issues"
  },
  "homepage": "https://github.com/MelnixDev/context-goblin#readme"
}
